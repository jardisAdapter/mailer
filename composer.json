{
    "name": "jardisadapter/mailer",
    "homepage": "https://jardis.io",
    "description": "SMTP mail client with STARTTLS, authentication, HTML and plain text support, attachments, and retry with exponential backoff; a building block of the open-source foundation that Jardis-generated DDD code runs on",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "jardissupport/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "phpstan/phpstan": "2.1.56",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\Mailer\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisAdapter/mailer/issues",
        "docs": "https://docs.jardis.io/en/adapter/mailer",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "mailer",
        "smtp",
        "email",
        "mail",
        "starttls",
        "transactional-email",
        "php",
        "domain-driven-design",
        "hexagonal-architecture",
        "jardis",
        "headgent"
    ]
}
