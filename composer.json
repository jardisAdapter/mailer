{
    "name": "jardisadapter/mailer",
    "description": "SMTP mail client with STARTTLS, authentication, HTML and plain text support, attachments",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/jardisSupport/contract"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\Mailer\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisAdapter/mailer",
    "support": {
        "issues": "https://github.com/jardisAdapter/mailer/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "mailer",
        "smtp",
        "email",
        "mail",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
